#
# work configuration (.env)
#
# Copy this file to `.env` next to the `work` script and fill in values for your environment.
#

# Git remote URL to clone for the main repo (used by `work init`).
GIT_REPO="$_URL_TO_REPO"

# Parent directory that will contain all worktrees created by `work checkout` / `work create`.
# Each worktree becomes a subdirectory under this path.
BRANCHES_PATH="$_PATH_TO_BRANCHES"

# Path to the main clone of your repository (used as the default git context for fetch/list/push and as the \"base\" repo).
# `work init` clones GIT_REPO into this directory.
MAIN_PATH="$_PATH_TO_MAIN_REPO"

# Default project key prefix used to identify issue branches (e.g. ABC for ABC123-something).
# If you only have one key, set this and leave PROJ_PREFIXES empty.
PROJ_PREFIX="$_PROJECT_PREFIX"

# Optional: support multiple project keys by providing an ERE alternation.
# Example: PROJ_PREFIXES="ABC|DEF|GHI"
# If set, this overrides PROJ_PREFIX for issue-id detection and issue-branch classification.
PROJ_PREFIXES=""

# Base URL for your issue tracker; `work details` appends the extracted issue id.
# Example: JIRA_BASE='https://jira.company.com/browse/'
JIRA_BASE='$_JIRA_BASE_URL'

# If true, after `work checkout` / `work create` the wrapper will cd into the new worktree automatically.
AUTO_CD_AFTER_CHECKOUT='true'

# Keyword for `work <keyword>` to cd to the main repo (MAIN_PATH), e.g. main, master, code.
# This is just a convenience alias in the `work` UI (it doesn't change your git branch name).
WORK_MAIN_ALIAS="main"

# Prefix to identify release branches (used by listings and checkout matching), e.g. release, rel.
# Release branches are classified as: ^${RELEASE_PREFIX}
RELEASE_PREFIX="release"

# Hook scripts directory after checkout/create: relative to this directory (the tooling checkout), or an absolute path.
# Hooks run in sorted order; executable files run directly; `*.sh` runs with bash.
# See `.work/post-worktree.d/README.md` here for layout.
WORK_POST_WORKTREE_DIR=".work/post-worktree.d"

# Optional: file where `work init` appends the `work()` wrapper function (default ~/.bashrc).
# Useful if you use zsh or a different bashrc location; point it at the file you actually source.
# WORK_BASHRC="${HOME}/.bashrc"
